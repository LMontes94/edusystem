# ──────────────────────────────────────────────
# EduSystem — Variables de entorno
# Copiar a .env y completar los valores
# NUNCA commitear el .env real al repositorio
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
BUILD_TARGET=development   # development | production

# ── PostgreSQL ───────────────────────────────
POSTGRES_PASSWORD=edusystem_pass
POSTGRES_DB=edusystem
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=            # dejar vacío en dev, obligatorio en prod

# ── JWT ──────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend ─────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-in-production
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://web:3000

# ── MinIO (Storage S3-compatible) ────────────
MINIO_ACCESS_KEY=edusystem_access
MINIO_SECRET_KEY=edusystem_secret_key_change_me
MINIO_BUCKET=edusystem
# En producción con S3 real, reemplazar por:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# ── Firebase (Push Notifications) ────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
